<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" isExecutable="true">
    <bpmn:startEvent id="Event_Start" name="Start" />
    <bpmn:task id="Activity_DoWork" name="Do Work" />
    <bpmn:endEvent id="Event_End" name="End" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Event_Start" targetRef="Activity_DoWork" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Activity_DoWork" targetRef="Event_End" />
  </bpmn:process>
</bpmn:definitions>
